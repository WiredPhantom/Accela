<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= note.noteTitle %> - Accela Notes</title>
  <link rel="stylesheet" href="/css/protection.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="icon" href="https://files.catbox.moe/bpi1je.gif" type="image/gif">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { margin: 0; padding: 0; overflow-x: hidden; font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }

    .minimal-nav {
      position: fixed;
      top: 20px;
      left: 20px;
      z-index: 9997;
      opacity: 0.7;
      transition: opacity 0.3s, transform 0.3s;
      transform: translateY(0);
      display: flex;
      gap: 10px;
      align-items: center;
    }
    .minimal-nav.hidden { transform: translateY(-100px); opacity: 0; pointer-events: none; }
    .minimal-nav:hover { opacity: 1; }
    .minimal-nav a {
      display: inline-block;
      padding: 10px 18px;
      background: rgba(79, 70, 229, 0.9);
      color: white;
      text-decoration: none;
      border-radius: 10px;
      font-size: 14px;
      font-weight: 600;
      font-family: 'Inter', -apple-system, sans-serif;
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
      transition: all 0.2s;
      white-space: nowrap;
    }
    .minimal-nav a:hover { background: rgba(79, 70, 229, 1); transform: translateX(-2px); }
    .minimal-nav a.fc-btn {
      background: rgba(0, 200, 160, 0.85);
      border-color: rgba(0, 255, 204, 0.4);
    }
    .minimal-nav a.fc-btn:hover { background: rgba(0, 220, 180, 1); transform: none; }

    @media print { .minimal-nav { display: none !important; } }
  </style>
</head>
<body class="no-select">

  <!-- ========== WATERMARK PROTECTION ========== -->
  <div class="watermark-overlay" id="watermarkOverlay">
    <div class="watermark-pattern" id="watermarkPattern"></div>
  </div>
  <div class="floating-watermark" id="floatingWatermark"></div>
  <div class="corner-watermark" id="cornerWatermark"></div>
  <div class="print-watermark" id="printWatermark" style="display: none;"></div>
  <!-- ========== END WATERMARK ========== -->

  <div class="minimal-nav" id="minimalNav">
    <a href="/notes/<%= note.subjectSlug %>/chapter/<%= note.chapterIndex %>">← Back</a>
    <a href="/chapters/<%= note.subjectSlug %>/chapter/<%= note.chapterIndex %>/topic/<%= note.topicIndex %>" class="fc-btn">📂 Go to Flashcards</a>
  </div>

  <%- note.htmlContent %>

  <script src="/js/protection.js"></script>
  <script>
    (function() {
      var username = '<%= typeof fullUser !== "undefined" && fullUser ? fullUser.username : (typeof user !== "undefined" && user ? user.username : "guest") %>';
      var email = '<%= typeof fullUser !== "undefined" && fullUser && fullUser.email ? fullUser.email : "" %>';
      if (typeof initProtection === 'function') { initProtection(username, email); }
    })();

    (function() {
      var lastScroll = 0;
      var backButton = document.getElementById('minimalNav');
      window.addEventListener('scroll', function() {
        var currentScroll = window.pageYOffset;
        if (currentScroll > 50 && currentScroll > lastScroll) {
          backButton.classList.add('hidden');
        } else if (currentScroll < lastScroll) {
          backButton.classList.remove('hidden');
        }
        if (currentScroll <= 10) { backButton.classList.remove('hidden'); }
        lastScroll = currentScroll;
      });
    })();
  </script>
</body>
</html>
