<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Choose Your Plan - Accela</title>
  <link rel="stylesheet" href="/chapters.css">
  <link rel="icon" href="https://files.catbox.moe/bpi1je.gif" type="image/gif">
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <style>
    .upgrade-wrap {
      max-width: 1180px;
      margin: 40px auto 80px;
      padding: 0 20px;
    }

    .upgrade-header {
      text-align: center;
      margin-bottom: 32px;
    }

    .upgrade-header h1 {
      color: #ffd700;
      font-size: 34px;
      margin-bottom: 12px;
    }

    .upgrade-header p {
      color: rgba(255, 255, 255, 0.7);
      font-size: 15px;
      max-width: 640px;
      margin: 0 auto;
    }

    .exam-info {
      display: inline-block;
      margin-top: 16px;
      padding: 8px 16px;
      background: rgba(0, 255, 204, 0.08);
      border: 1px solid rgba(0, 255, 204, 0.25);
      border-radius: 999px;
      color: #00ffcc;
      font-size: 13px;
      font-weight: 600;
    }

    .plans-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 20px;
      margin-top: 32px;
    }

    .plan-card {
      position: relative;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 16px;
      padding: 28px 24px;
      display: flex;
      flex-direction: column;
      transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    }

    .plan-card:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 215, 0, 0.4);
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
    }

    .plan-card.featured {
      background: linear-gradient(160deg, rgba(255, 215, 0, 0.10), rgba(255, 165, 0, 0.04));
      border: 2px solid rgba(255, 215, 0, 0.45);
    }

    .plan-card.owned {
      opacity: 0.6;
    }

    .plan-badge {
      position: absolute;
      top: -12px;
      right: 20px;
      padding: 4px 12px;
      background: linear-gradient(135deg, #ffd700, #ffaa00);
      color: #000;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    .plan-name {
      font-size: 18px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 4px;
    }

    .plan-coverage {
      font-size: 13px;
      color: rgba(255, 255, 255, 0.55);
      margin-bottom: 16px;
    }

    .plan-price {
      font-size: 36px;
      font-weight: 800;
      margin: 8px 0 4px;
    }

    .plan-price .currency {
      font-size: 18px;
      font-weight: 600;
      vertical-align: top;
      margin-right: 2px;
    }

    .plan-validity {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.5);
      margin-bottom: 18px;
    }

    .plan-features {
      list-style: none;
      padding: 0;
      margin: 0 0 24px;
      flex: 1;
    }

    .plan-features li {
      padding: 8px 0;
      font-size: 14px;
      color: rgba(255, 255, 255, 0.85);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .plan-features li:last-child { border-bottom: none; }

    .plan-features li::before {
      content: "✓";
      color: #00ffcc;
      font-weight: 700;
      margin-right: 8px;
    }

    .plan-btn {
      width: 100%;
      padding: 14px;
      border: none;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .plan-btn.primary {
      background: linear-gradient(135deg, #ffd700, #ffaa00);
      color: #000;
    }

    .plan-btn.secondary {
      background: rgba(255, 255, 255, 0.08);
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.18);
    }

    .plan-btn:hover:not(:disabled) {
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(255, 215, 0, 0.3);
    }

    .plan-btn:disabled {
      cursor: not-allowed;
      background: rgba(255, 255, 255, 0.05);
      color: rgba(255, 255, 255, 0.4);
    }

    .footer-actions {
      text-align: center;
      margin-top: 36px;
    }

    .skip-btn {
      background: transparent;
      color: rgba(255, 255, 255, 0.6);
      border: 1px solid rgba(255, 255, 255, 0.18);
      padding: 12px 28px;
      font-size: 14px;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.2s;
    }

    .skip-btn:hover {
      background: rgba(255, 255, 255, 0.05);
      color: rgba(255, 255, 255, 0.9);
    }

    /* Toast (kept from previous version) */
    #toast-container {
      position: fixed; top: 24px; right: 24px; z-index: 9999;
      display: flex; flex-direction: column; gap: 12px; pointer-events: none;
    }
    .toast {
      display: flex; align-items: flex-start; gap: 12px;
      min-width: 300px; max-width: 380px;
      padding: 16px 18px; border-radius: 12px;
      backdrop-filter: blur(12px);
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
      pointer-events: all;
      animation: toastIn 0.35s cubic-bezier(0.21, 1.02, 0.73, 1) forwards;
      position: relative; overflow: hidden;
    }
    .toast.hide { animation: toastOut 0.3s ease forwards; }
    .toast-success { background: rgba(0,255,180,0.12); border: 1px solid rgba(0,255,180,0.35); }
    .toast-error   { background: rgba(255,80,80,0.12);  border: 1px solid rgba(255,80,80,0.35); }
    .toast-info    { background: rgba(255,215,0,0.10);  border: 1px solid rgba(255,215,0,0.30); }
    .toast-icon  { font-size: 20px; flex-shrink: 0; margin-top: 1px; }
    .toast-body  { flex: 1; }
    .toast-title { font-size: 14px; font-weight: 700; margin-bottom: 3px; }
    .toast-success .toast-title { color: #00ffcc; }
    .toast-error   .toast-title { color: #ff6b6b; }
    .toast-info    .toast-title { color: #ffd700; }
    .toast-message { font-size: 13px; color: rgba(255,255,255,0.75); line-height: 1.4; }
    .toast-close { background: none; border: none; color: rgba(255,255,255,0.4); font-size: 16px; cursor: pointer; padding: 0; line-height: 1; flex-shrink: 0; transition: color 0.2s; }
    .toast-close:hover { color: rgba(255,255,255,0.8); }
    .toast-progress { position: absolute; bottom: 0; left: 0; height: 3px; border-radius: 0 0 12px 12px; animation: toastProgress linear forwards; }
    .toast-success .toast-progress { background: #00ffcc; }
    .toast-error   .toast-progress { background: #ff6b6b; }
    .toast-info    .toast-progress { background: #ffd700; }
    @keyframes toastIn  { from { opacity: 0; transform: translateX(60px) scale(0.95); } to { opacity: 1; transform: translateX(0) scale(1); } }
    @keyframes toastOut { from { opacity: 1; transform: translateX(0) scale(1); } to { opacity: 0; transform: translateX(60px) scale(0.95); } }
    @keyframes toastProgress { from { width: 100%; } to { width: 0%; } }
  </style>
</head>
<body>

  <div id="toast-container"></div>

  <header class="header">
    <div class="logo-title">
      <img src="https://files.catbox.moe/bpi1je.gif" alt="Animated Accela Logo" class="logo" />
      <h1 id="accela">Accela</h1>
    </div>
  </header>

  <div class="upgrade-wrap">
    <div class="upgrade-header">
      <h1>Choose Your Plan</h1>
      <p>
        Pick the syllabus you need. Notes &amp; flashcards are unlocked for the chapters in your plan.
        Every plan stays valid for <strong><%= validityMonths %> months</strong> from the day you buy it,
        so it covers your full prep window no matter when your exam is.
      </p>
      <div class="exam-info">⏳ Validity: <%= validityMonths %> months from purchase</div>
    </div>

    <div class="plans-grid">
      <% plans.forEach(function(plan) { %>
        <% var owned = activePlans.indexOf(plan.id) !== -1; %>
        <div class="plan-card <%= plan.id === 'complete' ? 'featured' : '' %> <%= owned ? 'owned' : '' %>">
          <% if (plan.badge) { %>
            <div class="plan-badge"><%= plan.badge %></div>
          <% } %>

          <div class="plan-name"><%= plan.name %></div>
          <div class="plan-coverage"><%= plan.chapterLabel %></div>

          <div class="plan-price">
            <span class="currency">₹</span><%= Math.round(plan.price / 100) %>
          </div>
          <div class="plan-validity">One-time • valid for <%= validityMonths %> months</div>

          <ul class="plan-features">
            <li>Notes for <%= plan.chapterLabel.toLowerCase() %></li>
            <li>Flashcards for <%= plan.chapterLabel.toLowerCase() %></li>
            <li><%= validityMonths %>-month validity from purchase</li>
            <% if (plan.id === 'complete') { %>
              <li>Best value — covers entire syllabus</li>
            <% } %>
          </ul>

          <% if (owned) { %>
            <button class="plan-btn secondary" disabled>✓ Already Active</button>
          <% } else { %>
            <button class="plan-btn primary" onclick="initiatePayment('<%= plan.id %>')">
              🔒 Get <%= plan.shortName %>
            </button>
          <% } %>
        </div>
      <% }); %>
    </div>

    <div class="footer-actions">
      <button class="skip-btn" onclick="skipToFree()">Continue with Free Access</button>
    </div>
  </div>

  <script>
    function showToast(type, title, message, duration) {
      duration = duration || 4000;
      var icons = { success: '🎉', error: '❌', info: 'ℹ️' };
      var container = document.getElementById('toast-container');
      var toast = document.createElement('div');
      toast.className = 'toast toast-' + type;
      toast.innerHTML =
        '<span class="toast-icon">' + icons[type] + '</span>' +
        '<div class="toast-body">' +
          '<div class="toast-title">' + title + '</div>' +
          '<div class="toast-message">' + message + '</div>' +
        '</div>' +
        '<button class="toast-close" onclick="dismissToast(this.parentElement)">✕</button>' +
        '<div class="toast-progress" style="animation-duration:' + duration + 'ms"></div>';
      container.appendChild(toast);
      setTimeout(function () { dismissToast(toast); }, duration);
    }
    function dismissToast(toast) {
      if (!toast || toast.classList.contains('hide')) return;
      toast.classList.add('hide');
      setTimeout(function () { toast.remove(); }, 300);
    }

    var username = "<%= username %>";

    if (!username) {
      showToast('error', 'Invalid Session', 'Please login again.');
      setTimeout(function () { window.location.href = '/login'; }, 2500);
    }

    async function initiatePayment(planId) {
      try {
        const orderResponse = await fetch('/payment/create-order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username: username, planId: planId })
        });

        const orderData = await orderResponse.json();

        if (!orderData.success) {
          showToast('error', 'Order Failed', orderData.message || 'Failed to create order. Please try again.');
          return;
        }

        const options = {
          key: orderData.key,
          amount: orderData.amount,
          currency: orderData.currency,
          name: 'Accela — ' + orderData.plan.name,
          description: orderData.plan.description,
          order_id: orderData.orderId,
          handler: async function (response) {
            const verifyResponse = await fetch('/payment/verify-payment', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                razorpay_order_id: response.razorpay_order_id,
                razorpay_payment_id: response.razorpay_payment_id,
                razorpay_signature: response.razorpay_signature,
                username: username,
                planId: planId
              })
            });

            const verifyData = await verifyResponse.json();

            if (verifyData.success) {
              await fetch('/payment/refresh-token', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username: username })
              });

              showToast('success', 'Payment Successful!', orderData.plan.name + ' activated. Redirecting…');
              setTimeout(function () { window.location.href = '/profile'; }, 2200);
            } else {
              showToast('error', 'Verification Failed', verifyData.message || 'Payment verification failed. Please contact support.');
            }
          },
          prefill: { name: username },
          theme: { color: '#ffd700' }
        };

        const razorpay = new Razorpay(options);
        razorpay.open();

      } catch (error) {
        console.error('Payment error:', error);
        showToast('error', 'Something Went Wrong', 'An unexpected error occurred. Please try again.');
      }
    }

    function skipToFree() { window.location.href = '/'; }
  </script>

</body>
</html>
