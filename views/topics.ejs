<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Topics — Chapter <%= chapterId %> - Accela</title>
  <link rel="stylesheet" href="/chapters.css">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Nastaliq+Urdu:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="icon" href="https://files.catbox.moe/bpi1je.gif" type="image/gif">
  <style>
    .premium-badge {
      display: inline-block;
      background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
      color: #0a092d;
      padding: 4px 12px;
      border-radius: 8px;
      font-size: 12px;
      font-weight: 700;
      margin-left: 12px;
      vertical-align: middle;
    }
    .lock-icon { font-size: 20px; margin-right: 8px; vertical-align: middle; }
    .topic-name-urdu { font-family: 'Noto Nastaliq Urdu', serif; direction: rtl; text-align: right; line-height: 1.8; }
    .topic-name-english { direction: ltr; text-align: left; }
  </style>
  <script>
    (function() {
      var t = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>
<body>

  <header class="header" style="position: relative;">
    <button class="theme-toggle" id="themeToggle" onclick="toggleTheme()" title="Toggle theme">☀️</button>
    <div class="logo-title">
      <img src="https://files.catbox.moe/bpi1je.gif" alt="Accela Logo" class="logo" />
      <h1 id="accela">Accela</h1>
    </div>
    <% if (isAuthenticated && user) { %>
      <div class="user-status <%= hasPremium ? 'premium' : '' %>" style="position:absolute; top:50%; right:40px; transform:translateY(-50%);">
        <% if (hasPremium) { %>⭐ Premium<% } else { %>👤 <%= user.username %><% } %>
      </div>
    <% } %>
  </header>

  <nav class="breadcrumb">
    <a href="/">🏠 Home</a>
    <span class="breadcrumb-separator">/</span>
    <a href="/chapters">📂 Flashcards</a>
    <span class="breadcrumb-separator">/</span>
    <a href="/chapters/<%= subjectSlug %>"><%= subjectName %></a>
    <span class="breadcrumb-separator">/</span>
    <span>Chapter <%= chapterId %></span>
  </nav>

  <div class="container">
    <section id="topics" class="section">
      <h1 class="title">📖 Chapter <%= chapterId %> — Topics</h1>

      <% if (!isAuthenticated) { %>
        <div class="premium-notice">
          🔐 Some topics are free, others require premium access.
          <a href="/login" style="color: inherit; text-decoration: underline;">Login</a> to unlock premium content.
        </div>
      <% } else if (!hasPremium) { %>
        <div class="premium-notice">
          🌟 Upgrade to Premium to unlock all topics and flashcards!
        </div>
      <% } %>

      <% if (topics.length === 0) { %>
        <div class="chapter-box">
          <p style="text-align:center; color:var(--text-muted);">No topics available yet. Check back soon!</p>
        </div>
      <% } else { %>
        <% topics.forEach(function(topic) {
             var isUrdu = /[\u0600-\u06FF]/.test(topic.topicName);
        %>
          <div class="chapter-box <%= topic.isPremium ? 'premium' : '' %>">
            <h2>
              Topic <%= topic._id %>
              <% if (topic.isPremium) { %>
                <span class="premium-badge"><span class="lock-icon">🔒</span>PREMIUM</span>
              <% } %>
            </h2>
            <p class="<%= isUrdu ? 'topic-name-urdu' : 'topic-name-english' %>"><%= topic.topicName %></p>

            <% if (topic.isPremium && !hasPremium) { %>
              <a href="/upgrade<%= isAuthenticated ? '?username=' + user.username : '' %>" class="btn" style="background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%); color: #0a092d;">
                🔓 Unlock Premium
              </a>
            <% } else { %>
              <a href="/chapters/<%= subjectSlug %>/chapter/<%= chapterId %>/topic/<%= topic._id %>" class="btn">View Flashcards</a>
            <% } %>
          </div>
        <% }); %>
      <% } %>
    </section>
  </div>

  <div class="buttons-container">
    <div class="button-row">
      <% if (isAuthenticated) { %>
        <form action="/logout" method="GET"><button type="submit" class="logout-btn">Logout</button></form>
        <% if (user && user.role === 'admin') { %><a href="/admin" class="admin-btn">Admin Panel</a><% } %>
      <% } else { %>
        <a href="/login" class="admin-btn">Login / Sign Up</a>
      <% } %>
    </div>
  </div>

  <script>
    function toggleTheme() {
      var html = document.documentElement;
      var current = html.getAttribute('data-theme') || 'dark';
      var next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      document.getElementById('themeToggle').textContent = next === 'dark' ? '☀️' : '🌙';
    }
    (function() {
      var t = localStorage.getItem('theme') || 'dark';
      document.getElementById('themeToggle').textContent = t === 'dark' ? '☀️' : '🌙';
    })();
  </script>

</body>
</html>
