<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= type === 'notes' ? 'Notes' : 'Flashcards' %> — Choose Subject - Accela</title>
  <link rel="stylesheet" href="/chapters.css">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Nastaliq+Urdu:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="icon" href="https://files.catbox.moe/bpi1je.gif" type="image/gif">
  <script>
    (function() {
      var t = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>
<body>

  <header class="header" style="position: relative;">
    <button class="theme-toggle" id="themeToggle" onclick="toggleTheme()" title="Toggle theme">☀️</button>
    <div class="logo-title">
      <img src="https://files.catbox.moe/bpi1je.gif" alt="Accela Logo" class="logo" />
      <h1 id="accela">Accela</h1>
    </div>
    <% if (isAuthenticated && user) { %>
      <div class="user-status <%= hasPremium ? 'premium' : '' %>" style="position:absolute; top:50%; right:40px; transform:translateY(-50%);">
        <% if (hasPremium) { %>⭐ Premium<% } else { %>👤 <%= user.username %><% } %>
      </div>
    <% } %>
  </header>

  <nav class="breadcrumb">
    <a href="/">🏠 Home</a>
    <span class="breadcrumb-separator">/</span>
    <span><%= type === 'notes' ? '📝 Notes' : '📂 Flashcards' %></span>
  </nav>

  <div class="container">
    <section class="section">
      <h1 style="text-align:center; font-size:28px; font-weight:700; margin-bottom:8px; color:var(--text);">
        <%= type === 'notes' ? '📝 Notes' : '📂 Flashcards' %>
      </h1>
      <p style="text-align:center; color:var(--text-muted); margin-bottom:32px; font-size:15px;">
        Subject choose karein
      </p>

      <div class="subjects-grid">
        <% subjects.forEach(function(sub) { %>
          <a href="/<%= type === 'notes' ? 'notes' : 'chapters' %>/<%= sub.id %>" class="subject-card">
            <span class="subject-card-accent" style="background: <%= sub.color %>;"></span>
            <span class="subject-card-emoji"><%= sub.emoji %></span>
            <div class="subject-card-name"><%= sub.name %></div>
            <div class="subject-card-urdu"><%= sub.urduName %></div>
            <div class="subject-card-desc"><%= sub.description %></div>
          </a>
        <% }); %>
      </div>
    </section>
  </div>

  <div class="buttons-container">
    <div class="button-row">
      <% if (isAuthenticated) { %>
        <form action="/logout" method="GET"><button type="submit" class="logout-btn">Logout</button></form>
        <% if (user && user.role === 'admin') { %><a href="/admin" class="admin-btn">Admin Panel</a><% } %>
        <a href="/profile" class="admin-btn" style="background:rgba(79,70,229,0.3); border-color:rgba(79,70,229,0.5);">Profile</a>
      <% } else { %>
        <a href="/login" class="admin-btn">Login / Sign Up</a>
      <% } %>
    </div>
  </div>

  <script>
    function toggleTheme() {
      var html = document.documentElement;
      var current = html.getAttribute('data-theme') || 'dark';
      var next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      document.getElementById('themeToggle').textContent = next === 'dark' ? '☀️' : '🌙';
    }
    (function() {
      var t = localStorage.getItem('theme') || 'dark';
      document.getElementById('themeToggle').textContent = t === 'dark' ? '☀️' : '🌙';
    })();
  </script>

</body>
</html>
