          <!-- Pending Password Resets -->
          <div class="container" style="margin-top: 24px;">
            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
              <h2 style="margin: 0;">🔑 Pending Password Resets <% if (pendingResets && pendingResets.length) { %><span style="background:#ff5577; color:#fff; font-size:12px; padding:2px 8px; border-radius:10px; margin-left:6px;"><%= pendingResets.length %></span><% } %></h2>
            </div>
            <p style="color:#888; font-size:13px; margin: 6px 0 14px;">
              Users who clicked "Forgot Password". If they didn't get the email, click <strong>Generate Link</strong> and share the URL via WhatsApp.
            </p>
            <% if (pendingResets && pendingResets.length > 0) { %>
              <div class="table-wrapper">
                <table>
                  <thead>
                    <tr>
                      <th>Username</th>
                      <th>Email</th>
                      <th>Requested</th>
                      <th>Expires</th>
                      <th style="text-align:right;">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% pendingResets.forEach(r => { %>
                      <tr>
                        <td><strong><%= r.username %></strong></td>
                        <td><small style="color:#aaa;"><%= r.email %></small></td>
                        <td><small><%= new Date(r.requestedAt).toLocaleString() %></small></td>
                        <td><small style="color:#ffaa55;"><%= new Date(r.expiresAt).toLocaleString() %></small></td>
                        <td style="text-align:right; white-space:nowrap;">
                          <button onclick="generateResetLink('<%= r.userId %>', '<%= r.username %>')"
                                  style="padding:6px 10px; background:rgba(0,255,204,0.15); border:1px solid rgba(0,255,204,0.4); color:#00ffcc; border-radius:6px; cursor:pointer; font-size:12px;">
                            🔗 Generate Link
                          </button>
                          <button onclick="dismissReset('<%= r.userId %>', '<%= r.username %>')"
                                  style="padding:6px 10px; background:rgba(255,85,119,0.12); border:1px solid rgba(255,85,119,0.4); color:#ff8899; border-radius:6px; cursor:pointer; font-size:12px; margin-left:4px;">
                            ✕ Dismiss
                          </button>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <p style="color:#666; font-style:italic;">No pending requests. (Users who forget their password will appear here.)</p>
            <% } %>
          </div>

          <!-- Unverified Email Accounts -->
          <div class="container" style="margin-top: 24px;">
            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
              <h2 style="margin: 0;">📧 Unverified Email Accounts <% if (unverifiedUsers && unverifiedUsers.length) { %><span style="background:#ffaa55; color:#000; font-size:12px; padding:2px 8px; border-radius:10px; margin-left:6px;"><%= unverifiedUsers.length %></span><% } %></h2>
            </div>
            <p style="color:#888; font-size:13px; margin: 6px 0 14px;">
              New users who haven't confirmed their email yet. They <strong>cannot purchase plans</strong> until verified. If they didn't get the email, share the code via WhatsApp, or click <strong>Verify Now</strong> to override.
            </p>
            <% if (unverifiedUsers && unverifiedUsers.length > 0) { %>
              <div class="table-wrapper">
                <table>
                  <thead>
                    <tr>
                      <th>Username</th>
                      <th>Email</th>
                      <th>Signed Up</th>
                      <th>Code</th>
                      <th style="text-align:right;">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% unverifiedUsers.forEach(u => { %>
                      <tr>
                        <td><strong><%= u.username %></strong></td>
                        <td><small style="color:#aaa;"><%= u.email %></small></td>
                        <td><small><%= new Date(u.createdAt).toLocaleString() %></small></td>
                        <td>
                          <% if (u.code) { %>
                            <code style="background:rgba(0,255,204,0.1); color:#00ffcc; padding:3px 8px; border-radius:4px; font-weight:700; letter-spacing:2px;"><%= u.code %></code>
                            <% if (u.codeExpiresAt && new Date(u.codeExpiresAt) < new Date()) { %>
                              <small style="color:#ff8080; display:block;">expired</small>
                            <% } %>
                          <% } else { %>
                            <small style="color:#666;">none</small>
                          <% } %>
                        </td>
                        <td style="text-align:right; white-space:nowrap;">
                          <button onclick="adminVerifyEmail('<%= u.userId %>', '<%= u.username %>')"
                                  style="padding:6px 10px; background:rgba(0,255,136,0.15); border:1px solid rgba(0,255,136,0.4); color:#00ff88; border-radius:6px; cursor:pointer; font-size:12px;">
                            ✓ Verify Now
                          </button>
                          <button onclick="adminResendVerification('<%= u.userId %>', '<%= u.username %>')"
                                  style="padding:6px 10px; background:rgba(0,170,255,0.15); border:1px solid rgba(0,170,255,0.4); color:#5fc0ff; border-radius:6px; cursor:pointer; font-size:12px; margin-left:4px;">
                            🔄 New Code
                          </button>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <p style="color:#666; font-style:italic;">All accounts have verified emails.</p>
            <% } %>
          </div>

          <!-- Recent Purchases / Revenue -->
