                <tbody>
                  <% users.forEach(user => { %>
                    <tr>
                      <td><%= user.userId %></td>
                      <td><%= user.username %></td>
                      <td>
                        <% if (user.role === 'admin') { %>
                          <span class="badge badge-admin">👑 <%= user.role %></span>
                        <% } else { %>
                          <span style="text-transform: capitalize;"><%= user.role %></span>
                        <% } %>
                      </td>
                      <td>
                        <% if (user.role === 'admin') { %>
                          <span class="badge badge-admin">All Access</span>
                        <% } else if (user.activePlans && user.activePlans.length > 0) { %>
