          <!-- User Subscriptions -->
          <div class="container">
            <h2>User Plans</h2>
            <p style="color: #888; margin-bottom: 16px; font-size: 13px;">
              Each plan has its own <%= validityMonths %>-month validity from purchase. Click ✏️ Manage to grant a new plan or revoke an existing one. Admins automatically have full access.
            </p>
            <div class="table-wrapper">
              <table>
                <thead>
                  <tr>
                    <th>User ID</th>
                    <th>Username</th>
                    <th>Role</th>
                    <th>Active Plans</th>
                    <th>Actions</th>
                  </tr>
