            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
              <h2 style="margin: 0;">💰 Revenue & Recent Purchases</h2>
              <a href="/admin/export-purchases.csv" style="padding: 8px 14px; background: rgba(0,255,136,0.15); border: 1px solid rgba(0,255,136,0.3); color: #00ff88; border-radius: 6px; text-decoration: none; font-size: 13px;">📥 Download CSV</a>
            </div>
            <div style="display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 16px;">
              <div style="flex: 1; min-width: 180px; padding: 14px; background: rgba(0,255,136,0.08); border: 1px solid rgba(0,255,136,0.2); border-radius: 8px;">
                <div style="font-size: 12px; color: #888; text-transform: uppercase;">Total Revenue</div>
                <div style="font-size: 24px; font-weight: bold; color: #00ff88;">₹<%= totalRevenue.toLocaleString('en-IN') %></div>
              </div>
              <div style="flex: 1; min-width: 180px; padding: 14px; background: rgba(255,215,0,0.08); border: 1px solid rgba(255,215,0,0.2); border-radius: 8px;">
                <div style="font-size: 12px; color: #888; text-transform: uppercase;">Paid Purchases</div>
                <div style="font-size: 24px; font-weight: bold; color: #ffd700;"><%= totalPurchaseCount %></div>
              </div>
            </div>
            <% if (recentPurchases && recentPurchases.length > 0) { %>
              <div class="table-wrapper">
                <table>
                  <thead>
                    <tr>
                      <th>Date</th>
                      <th>Username</th>
                      <th>Plan</th>
                      <th>Amount</th>
                      <th>Expires</th>
                      <th>Payment ID</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% recentPurchases.forEach(p => { %>
                      <tr>
                        <td><%= new Date(p.purchasedAt).toLocaleDateString() %></td>
                        <td><%= p.username %></td>
                        <td><%= p.planName %></td>
                        <td>
