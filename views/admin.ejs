                          <% user.activePlans.forEach(p => { %>
                            <span class="badge badge-premium" title="Expires <%= new Date(p.expiresAt).toLocaleDateString() %>" style="display: inline-flex; flex-direction: column; align-items: flex-start; line-height: 1.3; padding: 4px 8px;">
                              <span><%= p.shortName %><% if (p.legacy) { %> <small style="opacity:0.7;">(legacy)</small><% } %></span>
                              <small style="opacity: 0.75; font-weight: normal;">till <%= new Date(p.expiresAt).toLocaleDateString() %></small>
